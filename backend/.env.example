# Server
PORT=4000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Rate limiting (public endpoints: /health, /soroban/config)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Soroban / Stellar
SOROBAN_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Optional: contract id for the deployed Shelterflex contract
SOROBAN_CONTRACT_ID=

# Soroban contract IDs (set after deploying contracts)
SOROBAN_USDC_TOKEN_ID=
SOROBAN_STAKING_POOL_ID=
SOROBAN_STAKING_REWARDS_ID=

# Secret key used to sign Soroban transactions (e.g., your operator identity)
SOROBAN_ADMIN_SECRET=

# USDC token contract address (required in non-development environments)
# Testnet example: USDC_TOKEN_ADDRESS=0x8d3e2a4e2c3b4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9
# Mainnet example: USDC_TOKEN_ADDRESS=0xa0b86a33e6c4c4c4c4c4c4c4c4c4c4c4c4c4c4c4c4c
USDC_TOKEN_ADDRESS=

# Custodial wallet master keys (envelope encryption KEKs)
# REQUIRED for production: Base64-encoded 32-byte AES-256 key for encrypting wallet secret keys
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# SECURITY: Never commit actual keys to git. This is used for AES-256-GCM encryption at rest.
CUSTODIAL_WALLET_MASTER_KEY_V1=
CUSTODIAL_WALLET_MASTER_KEY_V2=
# Active version for new wallets and rotation target (1 or 2)
CUSTODIAL_WALLET_MASTER_KEY_ACTIVE_VERSION=1

# Custodial mode configuration
CUSTODIAL_MODE_ENABLED=true
CUSTODIAL_SIGNING_PAUSED=false

# Indexer configuration
INDEXER_POLL_MS=5000
INDEXER_START_LEDGER=


DATABASE_URL=postgres://app:app@localhost:5432/app
ENCRYPTION_KEY=supersecretkey123
# OTP Delivery (Resend)
# REQUIRED when OTP_DELIVERY_PROVIDER=email
OTP_DELIVERY_PROVIDER=console
RESEND_API_KEY=
RESEND_FROM_EMAIL=otp@yourdomain.com

# ---------------------------------------------------------------------------
# Payment Service Providers (PSP)
# ---------------------------------------------------------------------------
#
# Per-rail adapter selection.  Allowed values: stub | paystack | flutterwave
# Default is "stub" (safe for local development and CI — no real HTTP calls).
# Set to the real provider name in staging/production after configuring credentials below.
#
PSP_PROVIDER_PAYSTACK=stub
PSP_PROVIDER_FLUTTERWAVE=stub

# Webhook signature enforcement.
# Production always validates regardless of this flag.
WEBHOOK_SIGNATURE_ENABLED=false

# ---------------------------------------------------------------------------
# Paystack credentials  (required when PSP_PROVIDER_PAYSTACK=paystack)
# ---------------------------------------------------------------------------
# Secret key from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET=sk_live_
# Used as the payment callback after hosted checkout
PAYSTACK_CALLBACK_URL=https://yourapp.com/deposit/callback
# Override API base URL (useful for integration tests against a local mock)
# PAYSTACK_BASE_URL=https://api.paystack.co

# Webhook signing secret (set in Paystack dashboard → API keys & webhooks)
# This is the SAME value as PAYSTACK_SECRET for Paystack HMAC-SHA512 validation.

# ---------------------------------------------------------------------------
# Flutterwave credentials  (required when PSP_PROVIDER_FLUTTERWAVE=flutterwave)
# ---------------------------------------------------------------------------
# Secret key from https://developer.flutterwave.com/docs/integration-guides/authentication
FLUTTERWAVE_SECRET=FLWSECK_live_
# Redirect URL after hosted payment page (also used as payout callback)
FLUTTERWAVE_REDIRECT_URL=https://yourapp.com/deposit/callback
# Override API base URL (useful for integration tests against a local mock)
# FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
